{
    "manifest_version": 2,
    "name": "StudyStreak Companion",
    "version": "0.2.1",
    "description": "Daily study reminders and focus quality tracking for StudyStreak",
    "permissions": [
        "alarms",
        "notifications",
        "storage",
        "tabs",
        "idle",
        "webNavigation",
        "http://*/*",
        "https://*/*",
        "https://chichi.hackclub.app/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "scripts": ["background.js"],
        "persistent": true
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "studystreak-companion@studystreak.app",
            "strict_min_version": "140.0",
            "data_collection_permissions": {
                "required": [
                    "authenticationInfo",
                    "browsingActivity",
                    "websiteActivity"
                ]
            }
        },
        "gecko_android": {
            "strict_min_version": "142.0"
        }
    },
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["focus_overlay.js"],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "128": "icon128.png"
    },
    "browser_action": {
        "default_popup": "popup.html",
        "default_title": "StudyStreak"
    }
}
