{
    "manifest_version": 3,
    "name": "StudyStreak Companion",
    "version": "0.2.0",
    "description": "Daily study reminders and focus quality tracking for StudyStreak",
    "permissions": ["alarms", "notifications", "storage", "tabs", "idle"],
    "host_permissions": [
        "https://chichi.hackclub.app/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "scripts": ["background.js"],
        "service_worker": "background.js"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "studystreak-companion@studystreak.app",
            "strict_min_version": "121.0"
        }
    },
    "icons": {
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "StudyStreak"
    }
}
