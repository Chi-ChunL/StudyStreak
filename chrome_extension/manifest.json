{
    "manifest_version": 3,
    "name": "StudyStreak Companion",
    "version": "0.2.0",
    "description": "Daily study reminders and focus quality tracking for StudyStreak",
    "permissions": ["alarms", "notifications", "storage", "tabs", "idle", "scripting"],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "https://chichi.hackclub.app/*",
        "http://127.0.0.1:8000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["focus_overlay.js"],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "StudyStreak"
    }
}
