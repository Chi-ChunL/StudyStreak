/* #------------------light mode------------------- */

Screen.light-mode {
    background: #ded2b8;
    color: #2b2620;
}

.light-mode #main-container,
.light-mode #login-container {
    background: #f3e8d3;
    border: round #6f8190;
    color: #2b2620;
}

.light-mode #title,
.light-mode #login-title {
    color: #254f6f;
}

.light-mode #subtitle,
.light-mode #login-subtitle {
    color: #3d332d;
}

.light-mode #sync-status-label,
.light-mode #server-status-label,
.light-mode #account-label {
    color: #254f6f;
}

.light-mode TabbedContent,
.light-mode TabPane {
    background: #f3e8d3;
    color: #2b2620;
}

.light-mode Tabs {
    background: #e8d9bd;
    color: #2b2620;
}

.light-mode Tab {
    background: #e8d9bd;
    color: #3d332d;
}

.light-mode Tab.-active {
    background: #6f8799;
    color: #fff8e8;
    text-style: bold;
}

.light-mode Input {
    background: #fff8e8;
    color: #2b2620;
    border: round #9a8567;
}

.light-mode TextArea {
    background: #fff8e8;
    color: #2b2620;
    border: round #9a8567;
}

.light-mode Input:focus {
    background: #fff3db;
    border: round #6f8799;
}

.light-mode TextArea:focus {
    background: #fff3db;
    border: round #6f8799;
}

.light-mode Select {
    background: transparent;
    color: #2b2620;
    border: none;
}

.light-mode Select:focus {
    border: none;
}

.light-mode Input .input--placeholder {
    color: #5e534a;
}

.light-mode Input .input--cursor {
    background: #254f6f;
    color: #fff8e8;
}

.light-mode Input .input--selection {
    background: #d8e2e8;
    color: #1f2529;
}

.light-mode Select > SelectCurrent {
    background: #fff8e8;
    color: #2b2620;
    border: round #9a8567;
}

.light-mode Select:focus > SelectCurrent {
    background: #fff3db;
    color: #2b2620;
    border: round #6f8799;
}

.light-mode Select > SelectCurrent Static#label {
    background: transparent;
    color: #5e534a;
}

.light-mode Select > SelectCurrent.-has-value Static#label {
    color: #2b2620;
}

.light-mode Select > SelectCurrent .arrow {
    background: transparent;
    color: #4c443d;
}

.light-mode Select > SelectOverlay {
    background: #fff8e8;
    color: #2b2620;
    border: tall #6f8799;
}

.light-mode Select > SelectOverlay > .option-list--option {
    background: #fff8e8;
    color: #2b2620;
}

.light-mode Select > SelectOverlay > .option-list--option-highlighted,
.light-mode Select > SelectOverlay > .option-list--option-hover {
    background: #d8e2e8;
    color: #1f2529;
}

.light-mode Button,
.light-mode #login-button,
.light-mode #create-account-button,
.light-mode #log-button,
.light-mode #open-website-button,
.light-mode #start-focus-button,
