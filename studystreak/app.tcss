/* #------------------screen------------------- */

Screen {
    align: center middle;
}


/* #------------------main container------------------- */

#main-container {
    width: 90;
    height: auto;
    border: round grey;
    padding: 1 2;
}

#title {
    text-align: center;
    text-style: bold;
    color: grey;
    margin-bottom: 1;
}

#subtitle {
    text-align: center;
    color: white;
    margin-bottom: 1;
}

#global-message {
    margin-top: 1;
    text-align: center;
    color: yellow;
}


/* #------------------server status------------------- */

#sync-status-label,
#server-status-label {
    width: 100%;
    height: 1;
    text-align: right;
    color: #cfcfcf;
    margin-bottom: 0;
}

#sync-status-label {
    margin-bottom: 1;
}

/* #------------------account row------------------- */

#account-row {
    width: 100%;
    height: 3;
    align: center middle;
    margin-bottom: 1;
}

#account-label {
    width: 1fr;
    color: #cfcfcf;
}

#logout-button {
    width: 10;
    height: 1;
    background: transparent;
    color: #b8b8b8;
    border: none;
    padding: 0;
    content-align: center middle;
}

#logout-button:hover {
    background: #222222;
    color: white;
    border: none;
}


/* #------------------setup tour guide------------------- */

#tour-guide {
    width: 100%;
    height: auto;
    border: round #8a7a35;
    background: #17130a;
    padding: 1;
    margin-bottom: 1;
}

#tour-guide-text {
    text-align: center;
    color: #f0e6c8;
    margin-bottom: 1;
}

#tour-guide-buttons {
    height: auto;
    align: center middle;
}

#tour-go-button,
#tour-done-button,
#tour-skip-button,
#tour-end-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    margin: 0 1;
}

#tour-go-button:hover,
#tour-done-button:hover,
#tour-skip-button:hover,
#tour-end-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}


/* #------------------general widgets------------------- */

Input {
    margin-bottom: 1;
}

Button {
    margin: 0 1;
    background: #1f1f1f;
    color: #cfcfcf;
    border: tall #555555;
}

Button:hover {
    background: #2b2b2b;
    color: white;
    border: tall #888888;
}

TabbedContent {
    height: auto;
}

TabPane {
    padding: 1;
}


/* #------------------login screen------------------- */

#login-container {
    width: 60;
    height: auto;
    border: round grey;
    padding: 1 2;
}

#login-title {
    text-align: center;
    text-style: bold;
    color: grey;
    margin-bottom: 1;
}

#login-subtitle {
    text-align: center;
    color: white;
    margin-bottom: 1;
}

#login-username-input,
#login-password-input {
    margin-bottom: 1;
}

#remember-me-checkbox {
    color: #cfcfcf;
    margin-bottom: 1;
}

#login-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#login-button,
#create-account-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#login-button:hover,
#create-account-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#login-message {
    margin-top: 1;
    text-align: center;
    color: green;
}


/* #------------------dashboard------------------- */

#home-status-card,
#home-action-card,
#home-focus-readiness-card,
#home-review-card,
#home-wins-card,
#home-weak-topics-card,
#setup-checklist,
#recent-sessions,
#dashboard {
    text-align: left;
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}

#home-status-card {
    text-align: center;
    border: round #666666;
    background: #0b0b0b;
}

#home-action-card {
    border: round #777777;
    background: #0d0d0d;
    margin-bottom: 0;
}

#home-action-buttons {
    width: 100%;
    height: auto;
    align: center middle;
    margin-bottom: 2;
}

#home-prepare-focus-button {
    width: 26;
    background: #162415;
    color: white;
    border: tall #4d8a4d;
    margin: 0 1;
}

#home-open-focus-button,
#home-skip-action-button {
    width: 14;
    background: #141414;
    color: #d8d8d8;
    border: tall #666666;
    margin: 0 1;
}

#home-skip-action-button {
    color: #b8b8b8;
}

#home-prepare-focus-button:hover {
    background: #203720;
    border: tall #78b878;
}

#home-open-focus-button:hover,
#home-skip-action-button:hover {
    background: #222222;
    color: white;
    border: tall #999999;
}

#home-card-row-one,
#home-card-row-two {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

#home-focus-readiness-card,
#home-review-card,
#home-wins-card,
#home-weak-topics-card {
    width: 1fr;
    min-height: 8;
    margin: 0 1 0 0;
}

#home-review-card,
#home-weak-topics-card {
    margin-right: 0;
}


/* #------------------subject stats------------------- */

#subject-stats {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}


/* #------------------log session------------------- */

#log-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#subject-select {
    margin-bottom: 1;
}

#button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
    color: grey;
}

#log-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#log-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#message {
    margin-top: 1;
    text-align: center;
    color: green;
}


/* #------------------manage session------------------- */

#manage-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#session-select {
    margin-bottom: 1;
}

#manage-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#delete-selected-button {
    background: #2a1f1f;
    color: #d6c2c2;
    border: tall #6b4a4a;
}

#delete-selected-button:hover {
    background: #3a2929;
    color: white;
    border: tall #a66a6a;
}

#manage-message {
    margin-top: 1;
    text-align: center;
    color: yellow;
}


/* #------------------focus mode------------------- */

#focus-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#focus-subject-select,
#focus-topic-select,
#focus-website-input,
#focus-minutes-input,
#focus-quality-json-input {
    margin-bottom: 1;
}

#focus-website-input {
    height: 5;
}

#pomodoro-mode-checkbox {
    color: #cfcfcf;
    margin-bottom: 1;
}

#focus-quality-title {
    margin-top: 2;
    text-align: center;
    color: #cfcfcf;
}

#focus-quality-json-input {
    height: 8;
}

#focus-button-row,
#focus-quality-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#open-website-button,
#start-focus-button,
#cancel-focus-button,
#import-focus-json-button,
#clear-focus-json-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    margin: 0 1;
}

#open-website-button:hover,
#start-focus-button:hover,
#import-focus-json-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#cancel-focus-button,
#clear-focus-json-button {
    background: #2a1f1f;
    color: #d6c2c2;
    border: tall #6b4a4a;
}

#cancel-focus-button:hover,
#clear-focus-json-button:hover {
    background: #3a2929;
    color: white;
    border: tall #a66a6a;
}

#focus-timer {
    margin-top: 2;
    text-align: center;
    color: orange;
}

#focus-phase {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
}

#focus-message {
    margin-top: 1;
    text-align: center;
    color: green;
}

#focus-quality-message,
#focus-quality-summary {
    margin-top: 1;
    text-align: center;
}

FocusSessionScreen {
    background: black;
    align: center middle;
}

#focus-overlay {
    width: 100%;
    height: 100%;
    background: black;
    align: center middle;
}

#focus-overlay-content {
    width: 42;
    height: auto;
    align: center middle;
}

#focus-overlay-timer {
    width: 100%;
    height: auto;
    text-align: center;
    color: white;
    text-style: bold;
    margin-bottom: 2;
}

#focus-overlay-buttons {
    width: 100%;
    height: auto;
    align: center middle;
}

#focus-overlay-open-website-button,
#focus-overlay-stop-button {
    width: 18;
    background: #050505;
    color: #e8e8e8;
    border: tall #777777;
    margin: 0 1;
}

#focus-overlay-stop-button {
    background: #2a1111;
    color: #f0d0d0;
    border: tall #8a4a4a;
}

#focus-overlay-open-website-button:hover {
    background: #1a1a1a;
    color: white;
    border: tall #aaaaaa;
}

#focus-overlay-stop-button:hover {
    background: #3a1f1f;
    color: white;
    border: tall #c06a6a;
}


/* #--------------------------leaderboard-------------------------- */

#leaderboard-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#leaderboard-period-row {
    width: 100%;
    height: auto;
    align: center middle;
    margin-bottom: 1;
}

#leaderboard-today-button,
#leaderboard-week-button,
#leaderboard-all-button {
    width: 13;
    height: 1;
    margin: 0 1;
    background: transparent;
    color: #b8b8b8;
    border: none;
    padding: 0;
    content-align: center middle;
}

#leaderboard-today-button:hover,
#leaderboard-week-button:hover,
#leaderboard-all-button:hover {
    background: #222222;
    color: white;
    border: none;
}

#leaderboard-refresh-row {
    width: 100%;
    height: auto;
    align: center middle;
    margin-top: 0;
    margin-bottom: 1;
}

#refresh-leaderboard-button {
    width: 24;
    height: 3;
    margin: 0;
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    content-align: center middle;
}

#refresh-leaderboard-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#leaderboard {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-top: 1;
    margin-bottom: 1;
    height: auto;
}


/* #------------------settings layout------------------- */

#settings-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#settings-layout {
    width: 100%;
    height: auto;
}

#settings-sidebar {
    width: 24;
    height: auto;
    border-right: solid #555555;
    padding: 1;
    margin-right: 1;
}

#settings-content {
    width: 1fr;
    height: auto;
    padding: 1 2;
}

#settings-weekly-button,
#settings-health-button,
#settings-sync-button,
#settings-tour-button,
#settings-updates-button,
#settings-extension-button,
#settings-appearance-button,
#settings-sounds-button,
#settings-subjects-button,
#settings-privacy-button,
#settings-focus-import-button {
    width: 100%;
    height: 1;
    margin-bottom: 1;
    background: transparent;
    color: #b8b8b8;
    border: none;
    text-align: left;
    padding: 0 1;
}

#settings-weekly-button:hover,
#settings-health-button:hover,
#settings-sync-button:hover,
#settings-tour-button:hover,
#settings-updates-button:hover,
#settings-extension-button:hover,
#settings-appearance-button:hover,
#settings-sounds-button:hover,
#settings-subjects-button:hover,
#settings-privacy-button:hover,
#settings-focus-import-button:hover {
    background: #222222;
    color: white;
    border: none;
}

#weekly-goal-panel,
#setup-health-panel,
#sync-panel,
#tour-panel,
#updates-panel,
#extension-panel,
#appearance-panel,
#sounds-panel,
#subjects-panel,
#privacy-panel,
#focus-import-panel {
    width: 100%;
    height: auto;
}


#appearance-panel-title,
#sound-panel-title,
#tour-panel-title,
#updates-panel-title,
#extension-panel-title,
#privacy-panel-title {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
    margin-bottom: 1;
}

#ui-sounds-checkbox,
#focus-sound-checkbox,
#streak-sound-checkbox,
#achievement-sound-checkbox,
#focus-notification-checkbox,
#sync-failed-notification-checkbox,
#achievement-notification-checkbox,
#light-mode-checkbox {
    color: #cfcfcf;
    margin-bottom: 1;
}

#appearance-message,
#sounds-message,
#tour-message,
#updates-message,
#extension-message,
#privacy-message {
    margin-top: 1;
    text-align: center;
    color: green;
}

/* #------------------weekly goal settings------------------- */

#goal-panel-title {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
    margin-bottom: 1;
}

#weekly-goal-input {
    margin-bottom: 1;
}

#settings-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#save-goal-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#save-goal-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#settings-message {
    margin-top: 1;
    text-align: center;
    color: green;
}


/* #------------------sync settings------------------- */

#sync-panel-title {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
    margin-bottom: 1;
}

#setup-health-title {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
    margin-bottom: 1;
}

#setup-health-details {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}

#tour-details,
#updates-details,
#extension-details,
#privacy-details {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}

#sync-details {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}

#sync-button-row,
#tour-button-row,
#updates-button-row,
#extension-button-row,
#privacy-button-row,
#privacy-danger-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#privacy-button-stack {
    width: 100%;
    height: auto;
}

#sync-now-button,
#start-tour-button,
#mark-tour-complete-button,
#check-update-button,
#open-extension-guide-button,
#export-data-button,
#clear-focus-quality-data-button,
#reset-local-data-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    margin: 0 1;
}

#export-data-button {
    width: 18;
}

#clear-focus-quality-data-button {
    width: 26;
}

#reset-local-data-button {
    width: 30;
}

#sync-now-button:hover,
#start-tour-button:hover,
#mark-tour-complete-button:hover,
#check-update-button:hover,
#open-extension-guide-button:hover,
#export-data-button:hover,
#clear-focus-quality-data-button:hover,
#reset-local-data-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#sync-message,
#tour-message,
#updates-message,
#extension-message,
#privacy-message {
    margin-top: 1;
    text-align: center;
    color: green;
}


/* #------------------subject settings------------------- */

#subject-panel-title {
    text-align: center;
    color: #cfcfcf;
    text-style: bold;
    margin-bottom: 1;
}

#subject-subnav {
    width: 100%;
    height: 3;
    align: center middle;
    margin-bottom: 1;
}

#subject-add-tab,
#subject-edit-tab,
#subject-delete-tab {
    width: 14;
    height: 1;
    margin: 0 2;
    background: transparent;
    color: #b8b8b8;
    border: none;
    content-align: center middle;
    padding: 0;
}

#subject-add-tab:hover,
#subject-edit-tab:hover,
#subject-delete-tab:hover {
    color: white;
    background: #222222;
    border: none;
}

#subject-add-panel,
#subject-edit-panel,
#subject-delete-panel {
    width: 100%;
    height: auto;
}

#subject-add-title,
#edit-website-title,
#delete-subject-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#new-subject-input,
#new-subject-website-input,
#new-subject-topic-input,
#edit-website-subject-select,
#edit-website-input,
#edit-topic-input,
#delete-subject-select {
    margin-bottom: 1;
}

#new-subject-website-input,
#new-subject-topic-input,
#edit-website-input,
#edit-topic-input {
    height: 5;
}

.field-hint {
    color: #999999;
    margin-bottom: 0;
}

#focus-note-modal {
    width: 70;
    height: auto;
    border: round #777777;
    background: #111111;
    padding: 1 2;
}

#focus-note-title {
    text-align: center;
    text-style: bold;
    color: #cfcfcf;
    margin-bottom: 1;
}

#focus-note-summary {
    text-align: center;
    color: #999999;
    margin-bottom: 1;
}

#focus-note-input {
    height: 8;
    margin-bottom: 1;
}

#focus-note-button-row {
    height: auto;
    align: center middle;
}

#subject-button-row,
#edit-website-button-row,
#delete-subject-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#add-subject-button,
#update-website-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#add-subject-button:hover,
#update-website-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#delete-subject-button {
    background: #2a1f1f;
    color: #d6c2c2;
    border: tall #6b4a4a;
}

#delete-subject-button:hover {
    background: #3a2929;
    color: white;
    border: tall #a66a6a;
}

#subject-message,
#edit-website-message,
#delete-subject-message {
    margin-top: 1;
    text-align: center;
    color: green;
}

#delete-subject-message {
    color: yellow;
}


/* #------------------delete confirmation modal------------------- */

#delete-subject-confirm-box {
    width: 60;
    height: auto;
    border: round #8a4a4a;
    background: #111111;
    padding: 1 2;
    align: center middle;
}

#delete-subject-confirm-title {
    text-align: center;
    margin-bottom: 1;
}

#delete-subject-confirm-message {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#delete-subject-confirm-buttons {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#cancel-delete-subject-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    margin: 0 1;
}

#cancel-delete-subject-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#confirm-delete-subject-button {
    background: #3a1f1f;
    color: #e0c0c0;
    border: tall #8a4a4a;
    margin: 0 1;
}

#confirm-delete-subject-button:hover {
    background: #4a2929;
    color: white;
    border: tall #c06a6a;
}

#setup-tour-prompt-box,
#data-action-confirm-box {
    width: 70;
    height: auto;
    border: round #555555;
    background: #111111;
    padding: 1 2;
    align: center middle;
}

#setup-tour-prompt-title,
#data-action-confirm-title {
    text-align: center;
    margin-bottom: 1;
}

#setup-tour-prompt-message,
#data-action-confirm-message {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#setup-tour-prompt-buttons,
#data-action-confirm-buttons {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#start-setup-tour-button,
#skip-setup-tour-button,
#cancel-data-action-button,
#confirm-data-action-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
    margin: 0 1;
}

#start-setup-tour-button:hover,
#skip-setup-tour-button:hover,
#cancel-data-action-button:hover,
#confirm-data-action-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}


/* #-------------------achievement effect modal---------------------*/

#achievement-effect-box {
    width: 50;
    height: auto;
    border: round yellow;
    background: #111111;
    padding: 1 2;
    align: center middle;
}

#achievement-effect-title,
#achievement-effect-name,
#achievement-effect-message {
    text-align: center;
    margin-top: 1;
}

#achievement-effect-name {
    color: white;
}

#achievement-effect-message {
    color: #cfcfcf;
}

/* #---------------------streak effect modal------------------- */

#streak-effect-box {
    width: 45;
    height: auto;
    border: round orange;
    background: #111111;
    padding: 1 2;
    align: center middle;
}

#streak-fire {
    text-align: center;
}

#streak-effect-title {
    text-align: center;
    margin-top: 1;
}

#streak-effect-message {
    text-align: center;
    margin-top: 1;
}


/* #------------------timetable------------------- */

#timetable-title {
    text-align: center;
    color: #cfcfcf;
    margin-bottom: 1;
}

#timetable-top-row {
    height: auto;
    align: center middle;
    margin-bottom: 1;
}

#show-timetable-form-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#show-timetable-form-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#timetable-form-panel {
    width: 100%;
    height: auto;
    border: round #555555;
    padding: 1;
    margin-bottom: 1;
}

#timetable-subject-select,
#timetable-day-select,
#timetable-start-input,
#timetable-minutes-input {
    margin-bottom: 1;
}

#timetable-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#add-timetable-button {
    background: #2a2a2a;
    color: #e0e0e0;
    border: tall #777777;
}

#add-timetable-button:hover {
    background: #3a3a3a;
    color: white;
    border: tall #aaaaaa;
}

#hide-timetable-form-button {
    background: #2a1f1f;
    color: #d6c2c2;
    border: tall #6b4a4a;
}

#hide-timetable-form-button:hover {
    background: #3a2929;
    color: white;
    border: tall #a66a6a;
}

#timetable-message {
    margin-top: 1;
    text-align: center;
    color: green;
}

#today-timetable,
#timetable-grid {
    color: #cfcfcf;
    border: round #555555;
    padding: 1;
    margin-top: 1;
    margin-bottom: 1;
}

#manage-timetable-title {
    text-align: center;
    color: #cfcfcf;
    margin-top: 1;
    margin-bottom: 1;
}

#manage-timetable-select {
    margin-bottom: 1;
}

#manage-timetable-button-row {
    height: auto;
    align: center middle;
    margin-top: 1;
}

#delete-timetable-button {
    background: #2a1f1f;
    color: #d6c2c2;
    border: tall #6b4a4a;
}

#delete-timetable-button:hover {
    background: #3a2929;
    color: white;
    border: tall #a66a6a;
}


/* #------------------dark mode default override------------------- */

Screen {
    align: center middle;
    background: #0f0f0f;
    color: #cfcfcf;
}

#main-container,
#login-container {
    background: #111111;
    border: round grey;
    color: #cfcfcf;
}

#title,
#login-title {
    color: grey;
}

#subtitle,
#login-subtitle {
    color: white;
}

#sync-status-label,
#server-status-label,
#account-label {
    color: #cfcfcf;
}

TabbedContent,
TabPane {
    background: #111111;
    color: #cfcfcf;
}

Input {
    background: #1a1a1a;
    color: #cfcfcf;
    border: tall #555555;
}

Input:focus {
    border: tall #888888;
}

Select {
    background: transparent;
    color: #cfcfcf;
    border: none;
    height: 3;
}

Select:focus {
    border: none;
}

Select > SelectCurrent {
    background: #1a1a1a;
    color: #cfcfcf;
    border: tall #555555;
    height: 3;
}

Select:focus > SelectCurrent {
    background: #222222;
    color: #cfcfcf;
    border: tall #888888;
}

Select > SelectCurrent Static#label {
    background: transparent;
    color: #b8b8b8;
}

Select > SelectCurrent.-has-value Static#label {
    color: #cfcfcf;
}

Select > SelectCurrent .arrow {
    background: transparent;
    color: #b8b8b8;
}

Button,
#login-button,
#create-account-button,
#log-button,
#open-website-button,
#start-focus-button,
